# Root .gitignore for Real Estate project (frontend + backend)

# Node dependencies
node_modules/
**/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# Env files
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Runtime data
*.sqlite
*.sqlite3
*.db
*.db3
.DS_Store
Thumbs.db

# OS caches
*.swp
*~
.project
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sdf
*.cache
*.project
*.settings

# Build output - backend
dist/
build/
**/dist/
**/build/

# TypeScript
*.tsbuildinfo

# Frontend (Vite)
/public/build/
**/.vite/
**/.cache/

# Dependency directories for both packages (monorepo safe)
**/frontend/node_modules/
**/backend/node_modules/



# Optional npm history data
.npm
.npmrc

# IDE and editor workspace
*.sublime-project
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Temporary artifacts
*.tmp
*.temp

# Mac / Linux thumbnail
.Spotlight-V100
.Trashes

# Frontend dist output if built
dist_
/public/dist
**/dist/

# OS generated file
ehthumbs.db
Icon?

# Specific tools
yarn-error.log
package-lock.json
pnpm-lock.yaml

# SvelteKit/Vite / optional (if not needed in git)
.svelte-kit/

# Docker
docker-compose.override.yml

# keep repository clean
!.gitignore
